  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@vercel/og": "^0.11.1",
    "@types/react": "^19.2.0",
    "react": "^19.2.0",
    "satori": "^0.26.0",
    "typescript": "^5.9.0",
    "workers-og": "^0.0.27"
  },
  "author": "Lawrence Lin",
  "publishConfig": {
